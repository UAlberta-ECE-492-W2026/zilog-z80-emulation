.PHONY: clean waves


obj_dir/Vregister_file_tb: ./src/hdl/register_file.sv ./src/sim/register_file_tb.sv ./src/enum/reg_name.sv ./src/enum/exx_type.sv
	verilator --trace-vcd --binary -j 0 -Wall -cc $^ --top-module register_file_tb --timing +incdir+./src/enum

out/sim:
	mkdir -p ./out/sim

.stamp.run_register_file: obj_dir/Vregister_file_tb out/sim
	./$<

waves: .stamp.run_register_file
	gtkwave out/sim/register_file_tb.vcd

clean:
	rm -rf ./obj_dir/ ./out
