.PHONY: clean waves run_top


obj_dir/Vz80_top_tb: ./src/sim/z80_top_tb.sv
	verilator --trace-vcd --trace-structs --no-trace-top --binary -j 0 -Wall -cc $^ --top-module z80_top_tb --timing +incdir+./src/enum +incdir+./src/hdl

out/sim:
	mkdir -p ./out/sim

run_top: obj_dir/Vz80_top_tb out/sim
	./$<

waves: run_top
	gtkwave out/sim/z80_top_tb.vcd

clean:
	rm -rf ./obj_dir/ ./out
