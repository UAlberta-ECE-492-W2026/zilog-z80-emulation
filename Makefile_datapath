.PHONY: clean waves


obj_dir/Vdatapath_tb: ./src/hdl/uop.sv ./src/hdl/c_to_dp_intf.sv ./src/hdl/decode.sv ./src/hdl/alu.sv ./src/hdl/alu_status.sv ./src/hdl/alu_bit_op.sv ./src/hdl/alu_wrapper.sv ./src/hdl/register_file.sv ./src/hdl/buffer.sv ./src/enum/reg_name.sv ./src/enum/exx_type.sv ./src/hdl/datapath.sv ./src/sim/datapath_tb.sv
	verilator --trace-vcd --binary -j 0 -Wall -cc $^ --top-module datapath_tb --timing +incdir+./src/enum

out/sim:
	mkdir -p ./out/sim

.stamp.run_datapath: obj_dir/Vdatapath_tb out/sim
	./$<

waves: .stamp.run_datapath
	gtkwave out/sim/datapath_tb.vcd

clean:
	rm -rf ./obj_dir/ ./out
