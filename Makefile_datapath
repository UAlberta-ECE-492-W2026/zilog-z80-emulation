.PHONY: clean waves


obj_dir/Vdatapath_tb: ./src/hdl/alu.sv ./src/hdl/alu_wrapper.sv ./src/hdl/register_file.sv ./src/hdl/buffer.sv ./src/enum/reg_name.sv ./src/enum/exx_type.sv ./src/hdl/datapath.sv ./src/sim/datapath_tb.sv 
	verilator --trace-vcd --binary -j 0 -Wall -cc ./src/sim/datapath_tb.sv --top-module datapath_tb --timing +incdir+./src/enum +incdir+./src/hdl

out/sim:
	mkdir -p ./out/sim

.stamp.run_datapath: obj_dir/Vdatapath_tb out/sim
	./$<

waves: .stamp.run_datapath
	gtkwave out/sim/datapath_tb.vcd

clean:
	rm -rf ./obj_dir/ ./out
